# Supabase credentials for Offshore Tactics.
# Copy this file to `.env` for local development, and add the same two
# variables to Netlify (Site settings → Environment variables) for production.
#
# Both are EXPO_PUBLIC_* so Expo inlines them into the web/native bundle.
# The anon key is safe to expose in a client; row-level security protects data.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional OAuth sign-in buttons on the login wall. Set to 1 only after you've
# configured the matching provider in the Supabase dashboard (Authentication →
# Providers); otherwise leave unset so the button isn't shown. Magic-link and
# email/password work with just the two variables above.
EXPO_PUBLIC_ENABLE_GOOGLE=
EXPO_PUBLIC_ENABLE_APPLE=

# Link shown on the login wall and account screen (app-store / GDPR requirement).
EXPO_PUBLIC_PRIVACY_URL=https://offshoretactics.netlify.app/privacy
